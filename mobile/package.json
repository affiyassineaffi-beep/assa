{
  "name": "ssas-mobile",
  "version": "1.0.0",
  "private": true,
  "description": "SSAS — Plateforme Académique (native mobile shell, Capacitor)",
  "scripts": {
    "sync": "cap sync",
    "android": "cap run android",
    "open:android": "cap open android",
    "build:apk": "cd android && ./gradlew assembleDebug",
    "build:bundle": "cd android && ./gradlew bundleRelease",
    "icons": "cordova-res android --skip-config --copy --icon-source resources/icon.png --splash-source resources/splash.png"
  },
  "dependencies": {
    "@capacitor/android": "^6.1.2",
    "@capacitor/app": "^6.0.1",
    "@capacitor/core": "^6.1.2",
    "@capacitor/splash-screen": "^6.0.2",
    "@capacitor/status-bar": "^6.0.1"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.1.2",
    "cordova-res": "^0.15.4"
  }
}
