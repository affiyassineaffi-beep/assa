{
  "appId": "tn.ssas.academy",
  "appName": "SSAS",
  "webDir": "www",
  "bundledWebRuntime": false,
  "server": {
    "url": "https://REPLACE-ME.replit.app",
    "cleartext": false,
    "androidScheme": "https",
    "allowNavigation": [
      "*.replit.app",
      "*.replit.dev",
      "youtube.com",
      "*.youtube.com",
      "googleusercontent.com",
      "*.googleusercontent.com",
      "accounts.google.com"
    ]
  },
  "android": {
    "allowMixedContent": false,
    "captureInput": true,
    "webContentsDebuggingEnabled": false,
    "backgroundColor": "#0a0a0f"
  },
  "ios": {
    "contentInset": "always",
    "backgroundColor": "#0a0a0f"
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 1200,
      "launchAutoHide": true,
      "backgroundColor": "#f8d7e6",
      "showSpinner": false,
      "androidSplashResourceName": "splash",
      "splashFullScreen": true,
      "splashImmersive": true
    },
    "StatusBar": {
      "style": "DARK",
      "backgroundColor": "#0a0a0f"
    }
  }
}
